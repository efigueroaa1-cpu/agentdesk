# AgentDesk — Plantilla de configuracion
# Copia este archivo como .env y rellena tus valores reales.
# NUNCA subas el archivo .env a un repositorio.

# API Key de Google Gemini
# Obtén la tuya en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=TU_API_KEY_AQUI

# Hash bcrypt de la contrasena de acceso
# Genera el hash con:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'TuClave', bcrypt.gensalt(12)).decode())"
MASTER_PASSWORD_HASH=TU_HASH_BCRYPT_AQUI

# Licencia RSA local (ADR-0022) — OPCIONAL. Sin licencia el sistema opera
# en modo desktop libre. Para instalarla: pega el contenido de license.key
# en el SecurityPanel, o copia el archivo a %APPDATA%\AgentDesk\license.key.
# Ruta alternativa al archivo de licencia (dejar sin definir en escritorio):
# AGENTDESK_LICENSE_FILE=
