{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "AgentDesk",
  "version": "0.1.0",
  "identifier": "com.agentdesk.app",
  "build": {
    "beforeDevCommand":   "",
    "beforeBuildCommand": "npm run build",
    "devUrl":             "http://localhost:5173",
    "frontendDist":       "../loading"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title":      "AgentDesk Dashboard",
        "width":      1280,
        "height":     800,
        "minWidth":   900,
        "minHeight":  600,
        "resizable":  true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active":  true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/AgentDesk/**/*": "AgentDesk/"
    }
  }
}
